# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to either "openai" or "gemini"
LLM_PROVIDER=openai

# ── OpenAI (used when LLM_PROVIDER=openai) ────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini (used when LLM_PROVIDER=gemini) ─────────────────────────────
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── Mistral AI (used when LLM_PROVIDER=mistral) ──────────────────────────────
# MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-large-latest

# ── Ollama (local) ────────────────────────────────────────────────────────────

# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# ── Output ────────────────────────────────────────────────────────────────────
# Directory where generated PDFs are saved (default: paper/output/)
OUTPUT_DIR=paper/output

# ── MCP bridge (paper -> local MCP server over stdio) ────────────────────────
# Ensure the MCP server has been built before running /paper:
#   npm run build
# Default command invoked by paper/mcp_client.py:
#   node build/index.js
# PAPER_MCP_COMMAND=node
# PAPER_MCP_ARGS=build/index.js
# PAPER_MCP_TIMEOUT_SEC=8
# PAPER_MCP_WORKDIR=/absolute/path/to/cdli-mcp-server
